# ================================================================
# Configuración de Base de Datos
# ================================================================
DB_HOST=db
DB_NAME=erp_industrial
DB_USER=root
DB_PASSWORD=12345678&&&
DB_CHARSET=utf8mb4

# ================================================================
# Configuración de Aplicación
# ================================================================
APP_ENV=development
APP_DEBUG=true
APP_URL=http://localhost

# ================================================================
# Instrucciones de Uso:
# ================================================================
# 1. Renombra este archivo a .env (sin .example)
# 2. Actualiza los valores según tu entorno
# 3. Asegúrate de que .env está en .gitignore
# ================================================================
